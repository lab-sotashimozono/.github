#!/usr/bin/env bash
# pre-push — refuse to force-push (non-fast-forward) or delete a protected branch.
#
# This is the ONLY layer that actually *prevents* the push. GitHub Actions run after a push
# lands, and server-side branch protection is Team-gated for private repos on a Free org — so
# on this fleet the client is where prevention has to live. Installed into .git/hooks/pre-push
# by scripts/install-pre-push.sh.
#
# Intentional force-push (a rebase you meant):   PUSH_ALLOW_FORCE=1 git push --force ...
#
# git feeds the ref list on stdin, so we slurp it once and replay it to any pre-existing hook
# preserved as `pre-push.local` (e.g. gitleaks) — otherwise that hook would see empty stdin.
set -uo pipefail
PROTECTED="${PROTECTED_BRANCHES:-main master}"
ZERO=0000000000000000000000000000000000000000

INPUT=$(cat)
rc=0

while read -r _localref localsha remoteref remotesha; do
  [ -z "${remoteref:-}" ] && continue
  branch="${remoteref#refs/heads/}"
  [ "$branch" = "$remoteref" ] && continue          # not a branch ref
  case " $PROTECTED " in *" $branch "*) ;; *) continue ;; esac

  if [ "$localsha" = "$ZERO" ]; then
    echo "pre-push: REFUSING to delete protected branch '$branch'." >&2
    rc=1; continue
  fi

  [ "$remotesha" = "$ZERO" ] && continue            # new branch on the remote — nothing to clobber

  if ! git merge-base --is-ancestor "$remotesha" "$localsha" 2>/dev/null; then
    if [ "${PUSH_ALLOW_FORCE:-}" = "1" ]; then
      echo "pre-push: non-fast-forward to '$branch' ALLOWED (PUSH_ALLOW_FORCE=1)." >&2
    else
      echo "pre-push: REFUSING non-fast-forward (force) push to protected branch '$branch'." >&2
      echo "          remote $remotesha is not an ancestor of $localsha — this would" >&2
      echo "          overwrite history on '$branch'." >&2
      echo "          If you really mean it:  PUSH_ALLOW_FORCE=1 git push --force ..." >&2
      rc=1
    fi
  fi
done <<< "$INPUT"

[ "$rc" -ne 0 ] && exit "$rc"

# chain to a pre-existing hook, replaying the same stdin
CHAIN="$(dirname "$0")/pre-push.local"
if [ -x "$CHAIN" ]; then
  printf '%s\n' "$INPUT" | "$CHAIN" "$@"
  exit $?
fi
exit 0
